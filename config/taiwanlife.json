      ],
      "required_texts": [
        "理賠申請",
        "線上申請",
        "紙本申請"
      ]
    },
    {
      "id": "interest-rate",
      "name": "宣告利率",
      "path": "/investment-rate-interest-rate",
      "expected_title_contains": [
        "台灣人壽"
      ],
      "required_texts": [
        "宣告利率",
        "投資資訊"
      ]
    },
    {
      "id": "service-location",
      "name": "服務據點",
      "path": "/service-center-service-location",
      "expected_title_contains": [
        "台灣人壽"
      ],
      "required_texts": [
        "服務據點",
        "客戶協助"
      ]
    },
    {
      "id": "news",
      "name": "新聞中心",
      "path": "/news",
      "expected_title_contains": [
        "台灣人壽"
      ],
      "required_texts": [
        "新聞中心"
      ]
