  "link_crawl": {
    "enabled": true,
    "max_links": 120,
    "request_timeout_ms": 25000,
    "_include_hosts_comment": "未設定 include_hosts 時自動沿用頂層 allowed_hosts",
    "seed_paths": [
      "/",
      "/product-personal-life-TermLife",
      "/service-claim-online-e-claimsservice-claim-file-person",
      "/news"
    ],
    "ignore_url_keywords": [
      "#",
