# 共用時區
TZ=Asia/Taipei
GENERIC_TIMEZONE=Asia/Taipei

# n8n 基本設定
N8N_BIND_ADDR=127.0.0.1
N8N_HOST_PORT=5678
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_WEBHOOK_URL=http://localhost:5678/
N8N_SECURE_COOKIE=false
# 正式環境務必更換；建議使用 openssl rand -hex 32。
N8N_ENCRYPTION_KEY=replace-with-32-byte-random-secret
N8N_EXECUTIONS_DATA_MAX_AGE=336

# Execute Command 節點允許清單；若公司政策禁用 Execute Command，請改用 n8n/README.md 的 SSH 作法。
N8N_NODES_EXCLUDE=[]
MONITOR_WORKDIR=/opt/taiwanlife-monitor
MONITOR_PYTHON_BIN=./venv/bin/python
MONITOR_CONFIG=config/taiwanlife.json
MONITOR_OUTPUT_DIR=reports
MONITOR_SCHEDULER=manual

# Python 巡檢容器
MONITOR_IMAGE=taiwanlife-monitor:local
MONITOR_SHM_SIZE=2gb

# RPA84 功能流程；正式打開前請先校準 config/rpa84_scenarios.json selector。
MONITOR_ENABLE_RPA84=false

# SMTP 警示設定；密碼放 .env 或 n8n credentials，不要寫進 workflow JSON。
SMTP_HOST=smtp.internal.example.com
SMTP_PORT=587
SMTP_USER=monitor@example.com
SMTP_PASSWORD=
ALERT_FROM=monitor@example.com
ALERT_TO=web-admin@example.com,ops@example.com

# SSH 呼叫巡檢主機時使用，請在 n8n SSH credential 內保存私鑰或密碼。
MONITOR_SSH_HOST=monitor.internal.example.com
MONITOR_SSH_PORT=22
MONITOR_SSH_USER=monitor
MONITOR_SSH_WORKDIR=/opt/taiwanlife-monitor

# Power Automate / Teams Workflows webhook。Windows wrapper 只在 fail/warn 時 POST。
POWER_AUTOMATE_WEBHOOK_URL=
