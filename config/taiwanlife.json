{
  "target_name": "台灣人壽官網",
  "base_url": "https://www.taiwanlife.com/",
  "global_timeout_seconds": 1800,
  "allowed_hosts": [
    "www.taiwanlife.com",
    "ezbao.taiwanlife.com",
    "customer.taiwanlife.com",
    "consultancyservice.taiwanlife.com",
    "accessibility.taiwanlife.com"
  ],
  "ignore_url_keywords": [
    "facebook.com",
    "youtube.com",
    "instagram.com",
    "analytics.google.com",
    "google.com/rmkt",
    "googleadservices.com",
    "stats.g.doubleclick.net",
    "ad.doubleclick.net",
    "d.line-scdn.net",
    "google-analytics",
    "googletagmanager",
    "googletagmanager.com",
    "doubleclick",
    "line.me",
    "play.google.com",
    "apps.apple.com"
  ],
  "browser": {
    "headless": true,
    "timeout_ms": 45000,
    "locale": "zh-TW",
    "timezone_id": "Asia/Taipei",
    "viewport": {
      "width": 1920,
      "height": 1080
    },
    "user_agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/126.0.0.0 Safari/537.36",
    "extra_http_headers": {
      "Accept-Language": "zh-TW,zh;q=0.9,en-US;q=0.7,en;q=0.6"
    }
  },
  "ssl": {
    "enabled": true,
    "port": 443,
    "warn_days": 30,
    "fail_days": 7,
    "_hosts_comment": "未設定 hosts 時自動沿用頂層 allowed_hosts"
  },
  "retry": {
    "enabled": true,
    "max_attempts": 3,
    "base_delay_seconds": 1.5,
    "max_delay_seconds": 8.0
  },
  "pages": [
    {
      "id": "home",
      "name": "首頁",
