      "required_texts": [
        "商品資訊",
        "保戶服務",
        "投資資訊",
        "網路投保",
        "商品快搜",
        "最新消息",
        "服務據點"
      ],
      "full_page_screenshot": false
    },
    {
      "id": "product-life",
