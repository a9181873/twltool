      "enabled": false,
      "host_env": "SMTP_HOST",
      "port_env": "SMTP_PORT",
      "username_env": "SMTP_USER",
      "password_env": "SMTP_PASSWORD",
      "from_env": "ALERT_FROM",
      "to_env": "ALERT_TO",
      "starttls": true,
      "timeout_seconds": 20,
      "subject_prefix": "[台壽官網巡檢]"
