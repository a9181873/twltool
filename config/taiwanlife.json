  "search_check": {
    "enabled": true,
    "query": "壽險",
    "trigger_selectors": [
      "[data-testid='search-trigger']",
      "[aria-label*='搜尋']",
      "button[aria-expanded='false'][aria-haspopup='dialog']",
      "a[href*='search']",
      "a[hint*='搜尋']",
      "button[hint*='搜尋']",
      "text=搜尋全站",
      "text=搜尋"
    ],
    "input_selectors": [
      "input[placeholder*='搜尋']",
      "input[type='search']",
      "input[type='text']",
      "input:not([type])"
    ],
    "submit_selectors": [
      "button:has-text('搜尋')",
      "input[type='submit']",
      "[aria-label*='搜尋']"
    ],
    "expected_any_text": [
      "壽險",
      "搜尋結果",
      "商品項目",
      "壽險保障"
    ]
  },
  "rpa84": {
    "enabled": false,
    "schema_version": "1.0",
    "scenario_set": "RPA84 官網功能自動檢查",
    "notes": [
      "rpa84.scenarios 是目前正式需求與執行設定。",
      "enabled=false 的項目已完成需求盤點；補齊可執行操作步驟後再打開。",
      "有寄信、收藏、匯出、下載等副作用的流程須先確認測試帳號、測試收件人與清理規則。"
    ],
    "scenarios": [
      {
        "id": "1-1-search-site",
        "group": "搜尋",
        "name": "搜尋全站",
        "enabled": true,
        "input": {
          "keyword": "醫療"
        },
        "acceptance": [
          "產生搜尋結果",
          "搜尋結果不為 0 或頁面出現搜尋結果文字"
        ],
        "exception": [
          "無搜尋結果時產出 log 並通知"
        ],
        "steps": [
          {
            "action": "goto",
            "path": "/",
            "name": "開啟官網首頁"
          },
          {
            "action": "click_first",
            "name": "開啟全站搜尋",
            "optional": true,
            "selectors": [
              "[data-testid='search-trigger']",
              "[aria-label*='搜尋']",
              "button[aria-expanded='false'][aria-haspopup='dialog']",
              "a[href*='search']",
              "a[hint*='搜尋']",
              "button[hint*='搜尋']",
              "text=搜尋全站",
              "text=搜尋"
            ]
          },
          {
            "action": "fill_first",
            "name": "輸入搜尋關鍵字",
            "value": "醫療",
            "selectors": [
              "input[placeholder*='搜尋']",
              "input[type='search']",
              "input[type='text']",
              "input:not([type])"
            ]
          },
          {
            "action": "press_first",
            "name": "送出搜尋",
            "key": "Enter",
            "selectors": [
              "input[placeholder*='搜尋']",
              "input[type='search']",
              "input[type='text']",
              "input:not([type])"
            ]
          },
          {
            "action": "wait_for_load_state",
            "name": "等待搜尋結果",
            "state": "networkidle",
            "timeout_ms": 15000,
            "optional": true
          },
          {
            "action": "assert_any_text",
            "name": "確認搜尋結果",
            "texts": [
              "醫療",
              "搜尋結果",
              "商品項目"
            ]
          },
          {
            "action": "screenshot",
            "name": "搜尋結果截圖"
          }
        ]
      },
